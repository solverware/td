*.glo
*.gls
*.glg
*.acn
*.acr
*.alg

# === Nomenclature ===
*.nlo
*.nls

# === TikZ / externalization ===
*.tikz
*.tikzaux

# === Latexmk ===
*.run.xml

# === PDF build artifacts ===
*.dvi
*.xdv

# === Editor-specific ===

# TeXstudio
*.txsuser
*.txsprofile

# TeXworks
*.synctex.gz(busy)

# === OS junk ===
.DS_Store
Thumbs.db

# === Temporary / backup files ===
*~
*.bak
*.tmp

# === Build directories (if you use them) ===
/build/
/out/
/dist/

